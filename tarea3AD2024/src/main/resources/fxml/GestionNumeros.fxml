<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity" prefHeight="1080.0"
            prefWidth="1920.0" xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.adrianpaneda.tarea3AD2024base.controller.GestionNumerosController">

   <children>
      <StackPane prefHeight="1080.0" prefWidth="1920.0"
                 style="-fx-background-image: url('/images/circo_background.jpg'); -fx-background-size: cover; -fx-background-position: center;">

         <AnchorPane style="-fx-background-color: rgba(0, 0, 0, 0.45);">

            <VBox alignment="TOP_CENTER" layoutX="60.0" layoutY="60.0"
                  prefHeight="960.0" prefWidth="1800.0" spacing="15.0"
                  style="-fx-background-color: rgba(255, 255, 255, 0.98); -fx-background-radius: 20; -fx-padding: 30; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 40, 0, 0, 8);">

               <Label text="GESTIÓN DE NÚMEROS" textFill="#2563eb">
                  <font><Font name="System Bold" size="34.0" /></font>
               </Label>

               <Label fx:id="lblNombreEspectaculo" text="Espectáculo: ..." textFill="#475569">
                  <font><Font name="System Bold" size="16.0" /></font>
               </Label>

               <HBox spacing="25.0" prefHeight="730.0">

                  <!-- ═══ PANEL IZQUIERDO ═══ -->
                  <VBox spacing="12.0" prefWidth="880.0">

                     <Label text="NÚMEROS DEL ESPECTÁCULO" textFill="#1e293b">
                        <font><Font name="System Bold" size="18.0" /></font>
                     </Label>
                     <Label prefHeight="2.0" prefWidth="880.0" style="-fx-background-color: #2563eb;" />

                     <TableView fx:id="tablaNumeros" prefHeight="520.0" prefWidth="880.0"
                                style="-fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10;">
                        <columns>
                           <TableColumn fx:id="colId" prefWidth="80.0" text="ID"
                                        style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-alignment: CENTER;" />
                           <TableColumn fx:id="colNombre" prefWidth="300.0" text="Nombre"
                                        style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-alignment: CENTER-LEFT;" />
                           <TableColumn fx:id="colDuracion" prefWidth="130.0" text="Duración (min)"
                                        style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-alignment: CENTER;" />
                           <TableColumn fx:id="colOrden" prefWidth="100.0" text="Orden"
                                        style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-alignment: CENTER;" />
                        </columns>
                     </TableView>

                     <HBox spacing="15.0" alignment="CENTER">
                        <VBox.margin><Insets top="8.0" /></VBox.margin>
                        <Button fx:id="btnAnadir" mnemonicParsing="false"
                                onAction="#handleAnadir"
                                text="AÑADIR NÚMERO" textFill="white"
                                style="-fx-background-color: #2563eb; -fx-background-radius: 8; -fx-padding: 10 22 10 22; -fx-font-weight: bold; -fx-font-size: 13; -fx-cursor: hand;">
                           <font><Font name="System Bold" size="13.0" /></font>
                        </Button>
                        <Button fx:id="btnVolver" mnemonicParsing="false"
                                onAction="#handleVolver"
                                text="VOLVER A ESPECTÁCULOS" textFill="#475569"
                                style="-fx-background-color: transparent; -fx-border-color: #cbd5e1; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 22 10 22; -fx-font-weight: bold; -fx-font-size: 13; -fx-cursor: hand;">
                           <font><Font name="System Bold" size="13.0" /></font>
                        </Button>
                     </HBox>
                  </VBox>

                  <!-- ═══ PANEL DERECHO: FORMULARIO ═══ -->
                  <VBox fx:id="contenedorFormulario" spacing="0.0" prefWidth="780.0" prefHeight="730.0"
                        managed="false" visible="false">

                     <ScrollPane fx:id="scrollFormulario" prefWidth="780.0"
                                 fitToWidth="true" hbarPolicy="NEVER"
                                 style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
                        <VBox.vgrow><Priority fx:constant="ALWAYS" /></VBox.vgrow>

                        <VBox fx:id="panelFormulario" spacing="12.0" style="-fx-padding: 5;">

                           <Label fx:id="lblTituloFormulario" text="AÑADIR NÚMERO" textFill="#2563eb">
                              <font><Font name="System Bold" size="20.0" /></font>
                           </Label>
                           <Label prefHeight="2.0" prefWidth="760.0" style="-fx-background-color: #2563eb;" />

                           <Label text="DATOS DEL NÚMERO" textFill="#1e293b">
                              <font><Font name="System Bold" size="15.0" /></font>
                              <VBox.margin><Insets top="8.0" /></VBox.margin>
                           </Label>

                           <VBox spacing="3.0">
                              <Label text="Nombre:" textFill="#475569">
                                 <font><Font name="System Bold" size="13.0" /></font>
                              </Label>
                              <TextField fx:id="txtNombre" promptText="Nombre del número"
                                         style="-fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-width: 2; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 7; -fx-font-size: 13;" />
                              <Label fx:id="lblErrorNombre" textFill="#dc2626" wrapText="true">
                                 <font><Font size="11.0" /></font>
                              </Label>
                           </VBox>

                           <VBox spacing="3.0">
                              <Label text="Duración (minutos, pasos de 0.5):" textFill="#475569">
                                 <font><Font name="System Bold" size="13.0" /></font>
                              </Label>
                              <Spinner fx:id="spinnerDuracion" prefWidth="200.0" style="-fx-font-size: 13;" />
                              <Label fx:id="lblErrorDuracion" textFill="#dc2626" wrapText="true">
                                 <font><Font size="11.0" /></font>
                              </Label>
                           </VBox>

                           <VBox spacing="3.0">
                              <Label text="Orden (posición en el espectáculo):" textFill="#475569">
                                 <font><Font name="System Bold" size="13.0" /></font>
                              </Label>
                              <TextField fx:id="txtOrden" promptText="Número entero (1, 2, 3...)"
                                         style="-fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-width: 2; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 7; -fx-font-size: 13;" />
                              <Label fx:id="lblErrorOrden" textFill="#dc2626" wrapText="true">
                                 <font><Font size="11.0" /></font>
                              </Label>
                           </VBox>

                           <!-- ARTISTAS -->
                           <Label text="ARTISTAS DEL NÚMERO" textFill="#1e293b">
                              <font><Font name="System Bold" size="15.0" /></font>
                              <VBox.margin><Insets top="8.0" /></VBox.margin>
                           </Label>
                           <Label text="Seleccione los artistas que participan en este número:" textFill="#64748b">
                              <font><Font size="12.0" /></font>
                           </Label>

                           <TableView fx:id="tablaArtistas" prefHeight="250.0" prefWidth="760.0"
                                      style="-fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10;">
                              <columns>
                                 <TableColumn fx:id="colSeleccionar" prefWidth="60.0" text="✓"
                                              style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-alignment: CENTER;" />
                                 <TableColumn fx:id="colArtistaNombre" prefWidth="300.0" text="Nombre"
                                              style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-alignment: CENTER-LEFT;" />
                                 <TableColumn fx:id="colArtistaEspecialidades" prefWidth="398.0" text="Especialidades"
                                              style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-alignment: CENTER-LEFT;" />
                              </columns>
                           </TableView>
                           <Label fx:id="lblErrorArtistas" textFill="#dc2626" wrapText="true">
                              <font><Font size="11.0" /></font>
                           </Label>

                        </VBox>
                     </ScrollPane>

                     <!-- BOTONES FIJOS -->
                     <HBox spacing="15.0" alignment="CENTER"
                           style="-fx-padding: 15 0 5 0; -fx-background-color: transparent;">
                        <Button fx:id="btnGuardar" mnemonicParsing="false"
                                onAction="#handleGuardar" text="GUARDAR" textFill="white"
                                style="-fx-background-color: #16a34a; -fx-background-radius: 8; -fx-padding: 10 28 10 28; -fx-font-weight: bold; -fx-font-size: 13; -fx-cursor: hand;">
                           <font><Font name="System Bold" size="13.0" /></font>
                        </Button>
                        <Button fx:id="btnCancelar" mnemonicParsing="false"
                                onAction="#handleCancelar" text="CANCELAR" textFill="#475569"
                                style="-fx-background-color: transparent; -fx-border-color: #cbd5e1; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 28 10 28; -fx-font-weight: bold; -fx-font-size: 13; -fx-cursor: hand;">
                           <font><Font name="System Bold" size="13.0" /></font>
                        </Button>
                     </HBox>

                  </VBox>

               </HBox>
            </VBox>
         </AnchorPane>
      </StackPane>
   </children>
</AnchorPane>
