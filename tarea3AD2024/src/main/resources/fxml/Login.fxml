<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" 
            prefHeight="1080.0" prefWidth="1920.0" 
            xmlns="http://javafx.com/javafx/21" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.adrianpaneda.tarea3AD2024base.controller.LoginController">
   
   <children>
      <!-- Capa de fondo con imagen -->
      <StackPane prefHeight="1080.0" prefWidth="1920.0" 
                 style="-fx-background-image: url('/images/circo_background.jpg'); -fx-background-size: cover; -fx-background-position: center;">
         
         <!-- Overlay oscuro para suavizar el fondo -->
         <AnchorPane style="-fx-background-color: rgba(0, 0, 0, 0.45);">
            
            <!-- Panel central de login -->
            <VBox alignment="CENTER" layoutX="685.0" layoutY="290.0" prefHeight="500.0" prefWidth="550.0" 
                  spacing="25.0" 
                  style="-fx-background-color: rgba(255, 255, 255, 0.98); -fx-background-radius: 20; -fx-padding: 60; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 40, 0, 0, 8);">
               
               <!-- Título -->
               <Label text="GESTIÓN CIRCO" textFill="#2563eb">
                  <font>
                     <Font name="System Bold" size="42.0" />
                  </font>
               </Label>
               
               <Label text="Iniciar Sesión" textFill="#64748b">
                  <font>
                     <Font size="20.0" />
                  </font>
                  <VBox.margin>
                     <Insets bottom="15.0" />
                  </VBox.margin>
               </Label>
               
               <!-- Campo Usuario -->
               <VBox spacing="8.0">
                  <Label text="Usuario:" textFill="#0f172a">
                     <font>
                        <Font name="System Bold" size="16.0" />
                     </font>
                  </Label>
                  <TextField fx:id="txtUsuario" promptText="Nombre de usuario" 
                             style="-fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 14; -fx-font-size: 15; -fx-text-fill: #1e293b;">
                     <font>
                        <Font size="15.0" />
                     </font>
                  </TextField>
               </VBox>
               
               <!-- Campo Contraseña -->
               <VBox spacing="8.0">
                  <Label text="Contraseña:" textFill="#0f172a">
                     <font>
                        <Font name="System Bold" size="16.0" />
                     </font>
                  </Label>
                  <PasswordField fx:id="txtPassword" promptText="Contraseña" 
                                style="-fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 14; -fx-font-size: 15; -fx-text-fill: #1e293b;">
                     <font>
                        <Font size="15.0" />
                     </font>
                  </PasswordField>
               </VBox>
               
               <!-- Botón Login -->
               <Button fx:id="btnLogin" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogin" 
                       text="INICIAR SESIÓN" textFill="white" 
                       style="-fx-background-color: #2563eb; -fx-background-radius: 8; -fx-padding: 16; -fx-font-weight: bold; -fx-font-size: 16; -fx-cursor: hand;">
                  <font>
                     <Font name="System Bold" size="16.0" />
                  </font>
                  <VBox.margin>
                     <Insets top="15.0" />
                  </VBox.margin>
               </Button>
               
               <!-- Label de error -->
               <Label fx:id="lblError" textFill="#dc2626" wrapText="true" alignment="CENTER" maxWidth="450.0">
                  <font>
                     <Font name="System Bold" size="15.0" />
                  </font>
               </Label>
               
            </VBox>
         </AnchorPane>
      </StackPane>
   </children>
</AnchorPane>