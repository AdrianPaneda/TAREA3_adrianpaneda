<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="1080.0" prefWidth="1920.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.adrianpaneda.tarea3AD2024base.controller.ArtistaController">

   <children>
      <!-- Fondo con imagen -->
      <StackPane prefHeight="1080.0" prefWidth="1920.0"
                 style="-fx-background-image: url('/images/circo_background.jpg'); -fx-background-size: cover; -fx-background-position: center;">

         <!-- Overlay oscuro -->
         <AnchorPane style="-fx-background-color: rgba(0, 0, 0, 0.45);">

            <!-- Contenedor principal -->
            <VBox alignment="TOP_CENTER" layoutX="260.0" layoutY="80.0" prefHeight="920.0" prefWidth="1400.0"
                  spacing="25.0"
                  style="-fx-background-color: rgba(255, 255, 255, 0.98); -fx-background-radius: 20; -fx-padding: 50; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 40, 0, 0, 8);">

               <!-- Título -->
               <Label text="MI FICHA EN EL CIRCO" textFill="#2563eb">
                  <font>
                     <Font name="System Bold" size="38.0" />
                  </font>
                  <VBox.margin>
                     <Insets bottom="5.0" />
                  </VBox.margin>
               </Label>

               <!-- ═══ SECCIÓN DATOS PERSONALES ═══ -->
               <VBox spacing="15.0">

                  <Label text="DATOS PERSONALES" textFill="#1e293b">
                     <font>
                        <Font name="System Bold" size="22.0" />
                     </font>
                  </Label>

                  <!-- Separador -->
                  <Label prefHeight="2.0" prefWidth="1300.0"
                         style="-fx-background-color: #2563eb;" />

                  <!-- Campos de datos -->
                  <VBox spacing="12.0">
                     <VBox.margin>
                        <Insets top="5.0" left="10.0" />
                     </VBox.margin>

                     <!-- Nombre -->
                     <HBox spacing="10.0" alignment="CENTER_LEFT">
                        <Label text="Nombre:" textFill="#475569" prefWidth="150.0">
                           <font><Font name="System Bold" size="16.0" /></font>
                        </Label>
                        <Label fx:id="lblNombre" textFill="#0f172a">
                           <font><Font size="16.0" /></font>
                        </Label>
                     </HBox>

                     <!-- Email -->
                     <HBox spacing="10.0" alignment="CENTER_LEFT">
                        <Label text="Email:" textFill="#475569" prefWidth="150.0">
                           <font><Font name="System Bold" size="16.0" /></font>
                        </Label>
                        <Label fx:id="lblEmail" textFill="#0f172a">
                           <font><Font size="16.0" /></font>
                        </Label>
                     </HBox>

                     <!-- Nacionalidad -->
                     <HBox spacing="10.0" alignment="CENTER_LEFT">
                        <Label text="Nacionalidad:" textFill="#475569" prefWidth="150.0">
                           <font><Font name="System Bold" size="16.0" /></font>
                        </Label>
                        <Label fx:id="lblNacionalidad" textFill="#0f172a">
                           <font><Font size="16.0" /></font>
                        </Label>
                     </HBox>

                     <!-- Apodo -->
                     <HBox spacing="10.0" alignment="CENTER_LEFT">
                        <Label text="Apodo:" textFill="#475569" prefWidth="150.0">
                           <font><Font name="System Bold" size="16.0" /></font>
                        </Label>
                        <Label fx:id="lblApodo" textFill="#0f172a">
                           <font><Font size="16.0" /></font>
                        </Label>
                     </HBox>

                     <!-- Especialidades -->
                     <HBox spacing="10.0" alignment="CENTER_LEFT">
                        <Label text="Especialidades:" textFill="#475569" prefWidth="150.0">
                           <font><Font name="System Bold" size="16.0" /></font>
                        </Label>
                        <Label fx:id="lblEspecialidades" textFill="#0f172a" wrapText="true" maxWidth="1100.0">
                           <font><Font size="16.0" /></font>
                        </Label>
                     </HBox>

                  </VBox>
               </VBox>

               <!-- ═══ SECCIÓN TRAYECTORIA ═══ -->
               <VBox spacing="15.0">
                  <VBox.margin>
                     <Insets top="10.0" />
                  </VBox.margin>

                  <Label text="TRAYECTORIA EN EL CIRCO" textFill="#1e293b">
                     <font>
                        <Font name="System Bold" size="22.0" />
                     </font>
                  </Label>

                  <!-- Separador -->
                  <Label prefHeight="2.0" prefWidth="1300.0"
                         style="-fx-background-color: #2563eb;" />

                  <!-- Tabla de trayectoria -->
                  <TableView fx:id="tablaTrayectoria" prefHeight="320.0" prefWidth="1300.0"
                             style="-fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10;">
                     <columns>
                        <TableColumn fx:id="colEspectaculo" prefWidth="700.0" text="Espectáculo"
                                     style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-alignment: CENTER-LEFT;" />
                        <TableColumn fx:id="colNumero" prefWidth="598.0" text="Número"
                                     style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-alignment: CENTER-LEFT;" />
                     </columns>
                  </TableView>

               </VBox>

               <!-- ═══ BOTONES ═══ -->
               <HBox alignment="CENTER" spacing="20.0">
                  <VBox.margin>
                     <Insets top="15.0" />
                  </VBox.margin>

                  <!-- Ver Espectáculos -->
                  <Button fx:id="btnVerEspectaculos" mnemonicParsing="false"
                          onAction="#handleVerEspectaculos"
                          text="VER ESPECTÁCULOS" textFill="white"
                          style="-fx-background-color: #2563eb; -fx-background-radius: 8; -fx-padding: 14 30 14 30; -fx-font-weight: bold; -fx-font-size: 15; -fx-cursor: hand;">
                     <font><Font name="System Bold" size="15.0" /></font>
                  </Button>

                  <!-- Cerrar Sesión -->
                  <Button fx:id="btnCerrarSesion" mnemonicParsing="false"
                          onAction="#handleCerrarSesion"
                          text="CERRAR SESIÓN" textFill="#475569"
                          style="-fx-background-color: transparent; -fx-border-color: #cbd5e1; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 14 30 14 30; -fx-font-weight: bold; -fx-font-size: 15; -fx-cursor: hand;">
                     <font><Font name="System Bold" size="15.0" /></font>
                  </Button>

               </HBox>

            </VBox>
         </AnchorPane>
      </StackPane>
   </children>
</AnchorPane>
